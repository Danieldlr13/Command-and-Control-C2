# ─────────────────────────────────────────────
#  Nexus C2 — Configuración del paquete agente
#  Edita este archivo ANTES de correr build_package.sh
# ─────────────────────────────────────────────

# IP de tu laptop (donde corre el servidor C2)
# Ejemplo: http://192.168.1.57:8080
NEXUS_SERVER=http://192.168.1.57:8080

# Transporte: http | ws | dns
NEXUS_TRANSPORT=http
