# Nexus C2 — Variables de entorno
# Copia este archivo a .env y rellena los valores, luego arranca con:
#   source .env && python -m server
# O pásalas directamente:
#   GEMINI_API_KEY="..." OPENROUTER_API_KEY="..." python -m server

# ── NexusAI (asistente integrado) ─────────────────────────────────────
# Obtén tu key en: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=TU_GEMINI_API_KEY_AQUI

# Fallback cuando Gemini falla por quota/rate-limit
# Obtén tu key en: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=TU_OPENROUTER_API_KEY_AQUI

# Modelo de OpenRouter a usar (opcional, este es el default)
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Servidor ───────────────────────────────────────────────────────────
# API key para proteger el panel de operador (opcional)
# NEXUS_API_KEY=una_clave_secreta

# Permitir beacons sin cifrar (solo para debug)
# NEXUS_ALLOW_CLEAR=0

# Puerto DNS (por defecto 5354)
# NEXUS_DNS_PORT=5354
